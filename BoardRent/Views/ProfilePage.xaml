<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="BoardRent.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BoardRent.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="using:BoardRent.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:ProfileViewModel}"
    mc:Ignorable="d">

    <Grid>
        <StackPanel Padding="20" Spacing="10">
            <Grid Background="#555" Height="50">
                <TextBlock Text="My profile" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="Sign out" Background="Red" Foreground="White" HorizontalAlignment="Right" Margin="0,5,10,5"
                        Click="SignOut_Click"/>
            </Grid>


            <TabView
                IsAddTabButtonVisible="False" >
                <TabViewItem Header="Personal Info" IsSelected="True" IsClosable="False">
                    <ScrollViewer>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="100" Height="100" Background="#ccc">
                                    <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                </Border>
                                <Button Content="Remove Picture"
                                        Background="Red"
                                        Foreground="White"
                                        VerticalAlignment="Center"
                                        Command="{Binding RemoveAvatarCommand}"/>
                                <Button Content="Upload Avatar"
                                    Background="Blue"
                                    Foreground="White"
                                    Command="{Binding UploadAvatarCommand}"/>
                            </StackPanel>
                            <Grid ColumnSpacing="20" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0" Grid.Column="0"
                                     Header="Username"
                                     Text="{Binding Username}"
                                     IsReadOnly="True"/>

                                <TextBox Grid.Row="1" Grid.Column="0"
                                     Header="Email"
                                     Text="{Binding Email, Mode=TwoWay}"/>

                                <TextBox Grid.Row="2" Grid.Column="0"
                                     Header="Display Name"
                                     Text="{Binding DisplayName, Mode=TwoWay}"/>

                                <TextBox Grid.Row="3" Grid.Column="0"
                                     Header="Phone Number"
                                     Text="{Binding PhoneNumber, Mode=TwoWay}"/>

                                <TextBox Grid.Row="0" Grid.Column="1"
                                     Header="Street Name"
                                     Text="{Binding StreetName, Mode=TwoWay}"/>

                                <TextBox Grid.Row="1" Grid.Column="1"
                                     Header="Street Number"
                                     Text="{Binding StreetNumber, Mode=TwoWay}"/>

                                <TextBox Grid.Row="2" Grid.Column="1"
                                     Header="City"
                                     Text="{Binding City, Mode=TwoWay}"/>

                                <TextBox Grid.Row="3" Grid.Column="1"
                                     Header="Country"
                                     Text="{Binding Country, Mode=TwoWay}"/>

                            </Grid>
                            <TextBlock Text="{Binding ProfileMessage}" Foreground="Green" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding ProfileError}" Foreground="Red" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            <Button Content="Save Changes"
                            Background="Green"
                            Foreground="White"
                            Command="{Binding SaveProfileCommand}" />
                        </StackPanel>
                    </ScrollViewer>

                </TabViewItem>
                <TabViewItem Header="Security" IsClosable="False">
                    <ScrollViewer>
                        <StackPanel>
                            <PasswordBox
                                     Header="Current Password"
                                     Password="{Binding CurrentPassword, Mode=TwoWay}"/>

                            <PasswordBox
                                     Header="New Password"
                                     Password="{Binding NewPassword, Mode=TwoWay}"/>

                            <PasswordBox
                                     Header="Confirm New Password"
                                     Password="{Binding ConfirmPassword, Mode=TwoWay}"/>
                            <Button Content="Save Changes"
                                Background="Green"
                                Foreground="White"
                                Command="{Binding SaveNewPasswordCommand}" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap"/>
                        </StackPanel>

                    </ScrollViewer>

                </TabViewItem>
                <TabViewItem Header="Booking History"  IsClosable="False"/>
                <TabViewItem Header="My Listings"  IsClosable="False"/>
            </TabView>
        </StackPanel>
    </Grid>
</Page>
